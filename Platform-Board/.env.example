# Vercel Postgres connection (auto-set when you link a Vercel Postgres DB)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Admin key – set this to any secret string, used for the admin panel
ADMIN_KEY=change-me-to-a-secret
